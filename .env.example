# EtherBrain — .env.example (raíz del repositorio)
#
# Copia este archivo como .env y rellena tus valores reales.
#   cp .env.example .env
#
# El archivo .env NUNCA debe subirse al repositorio (está en .gitignore).
#
# ── NOTA ─────────────────────────────────────────────────────────────────────
# Este archivo es un atajo para desarrollo rápido en la raíz del repo.
# La referencia completa con TODAS las variables está en:
#   ether-brain/.env.example
# ─────────────────────────────────────────────────────────────────────────────


# ── LLM — OBLIGATORIO ────────────────────────────────────────────────────────
#
# LLM_TYPE   : openai | anthropic | gemini | bedrock
# LLM_URL    : URL base del proveedor (sin path)
# LLM_TOKEN  : API key o token (vacío para Ollama local)
# LLM_MODEL  : nombre del modelo

# Cerebras
LLM_TYPE=openai
LLM_URL=https://api.cerebras.ai
LLM_TOKEN=csk-
LLM_MODEL=gpt-oss-120b

# OpenAI
# LLM_TYPE=openai
# LLM_URL=https://api.openai.com
# LLM_TOKEN=sk-
# LLM_MODEL=gpt-4o-mini

# Anthropic Claude
# LLM_TYPE=anthropic
# LLM_URL=https://api.anthropic.com
# LLM_TOKEN=sk-ant-
# LLM_MODEL=claude-haiku-4-5

# Google Gemini
# LLM_TYPE=gemini
# LLM_URL=https://generativelanguage.googleapis.com
# LLM_TOKEN=AIzaSy
# LLM_MODEL=gemini-2.0-flash

# Groq (gratuito en console.groq.com)
# LLM_TYPE=openai
# LLM_URL=https://api.groq.com
# LLM_TOKEN=gsk_
# LLM_MODEL=llama-3.3-70b-versatile

# Ollama local (sin token)
# LLM_TYPE=openai
# LLM_URL=http://localhost:11434
# LLM_TOKEN=
# LLM_MODEL=llama3.2


# ── AGENTE ────────────────────────────────────────────────────────────────────
# AGENT_NAME=mi-agente
# AGENT_MAX_STEPS=8
# LLM_MAX_TOKENS=4096
# LLM_TEMPERATURE=0.7


# ── SESIONES ──────────────────────────────────────────────────────────────────
SESSION_DIR=/tmp/etherbrain-sessions


# ── SERVIDOR HTTP (ether-brain-http.jar) ─────────────────────────────────────
# HTTP_PORT=8080
# AUTH_TOKEN=mi-token-secreto
# HTTP_RATE_LIMIT_RPM=60


# ── TRANSPORTE MQTT (ether-brain-mqtt.jar) ───────────────────────────────────
# MQTT_BROKER=tcp://localhost:1883
# MQTT_REQUEST_TOPIC=etherbrain/requests
# MQTT_RESPONSE_TOPIC=etherbrain/responses


# ── LOGGING ───────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO

[
  // ── TIPO 1: Subprocess ─────────────────────────────────────────────────────
  // Ejecuta cualquier CLI como tool. Sin servidor extra, sin código Java.
  // ${arg} se sustituye por el valor del argumento.
  // ${__output__} → archivo temporal que el proceso escribe y EtherBrain lee.
  {
    "type":    "subprocess",
    "name":    "ocr_document",
    "description": "Extracts text from a PDF or scanned image using ether-ocr. Supports digital PDFs (pdftotext) and scanned PDFs/images (Tesseract OCR). Returns extracted plain text.",
    "command": ["ether-ocr", "ocr", "${file_path}", "${__output__}", "--lang", "${lang}"],
    "output":  "file",
    "input_schema": {
      "type": "object",
      "properties": {
        "file_path": {
          "type": "string",
          "description": "Absolute path to the PDF or image file"
        },
        "lang": {
          "type": "string",
          "description": "Tesseract language codes (default: spa+eng)",
          "default": "spa+eng"
        }
      },
      "required": ["file_path"]
    }
  },

  // ── TIPO 2: HTTP Proxy ─────────────────────────────────────────────────────
  // Delega a cualquier servicio HTTP. Con estado, sin overhead de fork.
  // ${ENV_VAR} en headers se resuelve desde el entorno del SO.
  {
    "type":        "http",
    "name":        "search_web",
    "description": "Searches the web for information about a topic. Use when the user asks about current events, specific facts, or anything that may require up-to-date information.",
    "endpoint":    "http://localhost:8090/search",
    "method":      "POST",
    "headers":     {
      "X-API-Key":  "${SEARCH_API_KEY}",
      "User-Agent": "EtherBrain/0.1.0"
    },
    "timeout_seconds": 15,
    "input_schema": {
      "type": "object",
      "properties": {
        "query":   {"type": "string", "description": "Search query"},
        "limit":   {"type": "integer", "description": "Max results (1-10)", "default": 5}
      },
      "required": ["query"]
    }
  },

  // ── TIPO 3: MCP (Model Context Protocol) ──────────────────────────────────
  // Conecta a un servidor MCP vía stdio.
  // EtherBrain descubre TODAS las tools del servidor automáticamente.
  // env: variables de entorno pasadas al proceso del servidor.
  {
    "type":        "mcp",
    "server_name": "ether-ocr-mcp",
    "command":     ["python3", "-m", "ether_ocr_mcp"],
    "env":         {
      "PYTHONPATH": "/Users/rafex/repository/github/rafex/ether/ether-ocr/python/src"
    }
  }

  // ── TIPO 4: SPI (ServiceLoader) ────────────────────────────────────────────
  // NO se configura aquí — es automático.
  // Cualquier JAR en el classpath con:
  //   META-INF/services/dev.rafex.etherbrain.ports.tools.Tool
  // se descubre automáticamente al arrancar.
  // Ver: docs/tools-externas.md#spi
]

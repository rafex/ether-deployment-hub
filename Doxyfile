# Doxygen configuration for Ether Java modules (phase 1)

PROJECT_NAME           = "Ether Framework"
PROJECT_BRIEF          = "Unified API docs for Ether modules"
OUTPUT_DIRECTORY       = docs/api/doxygen
CREATE_SUBDIRS         = NO
ALLOW_UNICODE_NAMES    = YES

OUTPUT_LANGUAGE        = English
OPTIMIZE_OUTPUT_JAVA   = YES
JAVADOC_AUTOBRIEF      = YES
QT_AUTOBRIEF           = NO
MARKDOWN_SUPPORT       = YES
AUTOLINK_SUPPORT       = YES
EXTRACT_ALL            = YES
EXTRACT_PRIVATE        = NO
EXTRACT_STATIC         = NO
EXTRACT_LOCAL_CLASSES  = YES
EXTRACT_ANON_NSPACES   = NO
HIDE_UNDOC_MEMBERS     = NO
HIDE_UNDOC_CLASSES     = NO
INHERIT_DOCS           = YES
BUILTIN_STL_SUPPORT    = YES

# INPUT is intentionally omitted here.
# The wrapper scripts (doxygenw.sh / generate-doxygen-docs.sh) derive the
# source paths automatically from releases/manifest.json (.modules[].projectDir)
# and append an INPUT block to a temporary Doxyfile at build time.
# To add a new module to the docs, add it to releases/manifest.json — no
# changes to this file are needed.
INPUT                  =
FILE_PATTERNS          = *.java *.md
RECURSIVE              = YES
EXCLUDE_SYMLINKS       = NO
EXCLUDE                = */target/* */src/test/* */.git/* */.settings/*
EXCLUDE_PATTERNS       = */generated/* */release-artifacts/*

USE_MDFILE_AS_MAINPAGE = README.md
SOURCE_BROWSER         = YES
INLINE_SOURCES         = NO
STRIP_CODE_COMMENTS    = NO
REFERENCED_BY_RELATION = YES
REFERENCES_RELATION    = YES
SORT_MEMBER_DOCS       = YES
SORT_BRIEF_DOCS        = YES
WARN_IF_UNDOCUMENTED   = NO
WARN_IF_DOC_ERROR      = YES
WARN_NO_PARAMDOC       = NO
QUIET                  = YES

GENERATE_HTML          = YES
HTML_OUTPUT            = html
HTML_FILE_EXTENSION    = .html
HTML_COLORSTYLE        = LIGHT
HTML_DYNAMIC_SECTIONS  = YES
GENERATE_TREEVIEW      = YES
DISABLE_INDEX          = NO
FULL_SIDEBAR           = YES
# Custom footer injects Mermaid CDN so ```mermaid fenced blocks render as diagrams.
# GitHub renders the same blocks natively, so no source changes are needed.
HTML_FOOTER            = docs/doxygen/footer.html
GENERATE_LATEX         = NO
GENERATE_XML           = NO

HAVE_DOT               = YES
DOT_IMAGE_FORMAT       = svg
UML_LOOK               = YES
UML_LIMIT_NUM_FIELDS   = 50
CLASS_GRAPH            = YES
COLLABORATION_GRAPH    = YES
GROUP_GRAPHS           = YES
INCLUDE_GRAPH          = YES
INCLUDED_BY_GRAPH      = YES
CALL_GRAPH             = YES
CALLER_GRAPH           = YES
GRAPHICAL_HIERARCHY    = YES
DOT_CLEANUP            = YES
